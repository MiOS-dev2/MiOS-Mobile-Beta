
use core::ptr;


#[derive(Debug, Clone, Copy, PartialEq, Eq)]
#[repr(transparent)]
pub struct Color(u32);

impl Color {
    pub const fn new(red: u8, green: u8, blue: u8) -> Self {
        Self((blue as u32) << 16 | (green as u32) << 8 | red as u32)
    }
    pub const BLACK:     Self = Self(0x00000000);
    pub const WHITE:     Self = Self(0x00FFFFFF);
    pub const DARK_GRAY:  Self = Self(0x00404040);
    pub const LIGHT_GRAY: Self = Self(0x00C0C0C0);
    pub const RED:       Self = Self::new(255, 0, 0);
    pub const GREEN:     Self = Self::new(0, 255, 0);
    pub const BLUE:      Self = Self::new(0, 0, 255);
    pub const YELLOW:    Self = Self::new(255, 255, 0);
    pub const CYAN:      Self = Self::new(0, 255, 255);
    pub const MAGENTA:   Self = Self::new(255, 0, 255);
    pub const TITLE_BLUE: Self = Self::new(0, 80, 160);
    pub const DESKTOP_BLUE: Self = Self::new(58, 110, 165);
}

#[derive(Debug, Clone, Copy)]
pub struct FramebufferInfo {
    pub addr: u64,
    pub pitch: u32,
    pub width: u32,
    pub height: u32,
    pub bpp: u8,
}

pub struct VesaDisplay {
    fb: *mut u32,
    width: usize,
    height: usize,
    pitch: usize,
    bytes_per_pixel: usize,
    font: &'static [u8; 128 * 16],
}

impl VesaDisplay {
    /// Создать дисплей из Multiboot-информации
    pub unsafe fn from_multiboot(info: &FramebufferInfo) -> Option<Self> {
        if info.addr == 0 || info.width == 0 || info.height == 0 || info.bpp == 0 {
            return None;
        }
        Some(Self {
            fb: info.addr as *mut u32,
            width: info.width as usize,
            height: info.height as usize,
            pitch: info.pitch as usize,
            bytes_per_pixel: (info.bpp as usize) / 8,
            font: &FONT8X16,
        })
    }


    pub fn clear(&mut self, color: Color) {
        for y in 0..self.height {
            for x in 0..self.width {
                self.set_pixel(x, y, color);
            }
        }
    }


    #[inline]
    pub fn set_pixel(&mut self, x: usize, y: usize, color: Color) {
        if x >= self.width || y >= self.height { return; }
        let offset = y * self.pitch + x * self.bytes_per_pixel;
        unsafe {
            ptr::write_volatile((self.fb as *mut u8).add(offset) as *mut u32, color.0);
        }
    }

    pub fn draw_hline(&mut self, x1: usize, x2: usize, y: usize, color: Color) {
        for x in x1..=x2.min(self.width - 1) { self.set_pixel(x, y, color); }
    }
    pub fn draw_vline(&mut self, x: usize, y1: usize, y2: usize, color: Color) {
        for y in y1..=y2.min(self.height - 1) { self.set_pixel(x, y, color); }
    }

    pub fn fill_rect(&mut self, x: usize, y: usize, w: usize, h: usize, color: Color) {
        for dy in 0..h { self.draw_hline(x, x + w - 1, y + dy, color); }
    }


    pub fn draw_char(&mut self, x: usize, y: usize, ch: char, fg: Color, bg: Color) {
        if ch as u32 > 127 { return; }
        let idx = ch as usize;
        let glyph = &self.font[idx * 16..][..16];
        for (row, byte) in glyph.iter().enumerate() {
            for col in 0..8 {
                let bit = (byte >> (7 - col)) & 1;
                let color = if bit == 1 { fg } else { bg };
                self.set_pixel(x + col, y + row, color);
            }
        }
    }

    pub fn draw_text(&mut self, x: usize, y: usize, s: &str, fg: Color, bg: Color) {
        let mut cx = x;
        for ch in s.chars() {
            if ch == '\n' { continue; }
            self.draw_char(cx, y, ch, fg, bg);
            cx += 8;
            if cx + 8 > self.width { cx = x; /* можно добавить переход на новую строку */ }
        }
    }

    pub fn width(&self) -> usize { self.width }
    pub fn height(&self) -> usize { self.height }
}


static FONT8X16: [u8; 128 * 16] = [
    // 0x00 - 0x1F (непечатные – пустые)
    0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,
    0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,
    // ... (я заполню только несколько первых символов для примера,
    //  а ниже дам команду для генерации полного массива)
    // В реальном коде здесь будут все 128*16 байт.
    // Пользователь может вставить готовый шрифт из интернета.
];
